{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/proteogenomicsdb/main/nextflow_schema.json",
    "title": "nf-core/proteogenomicsdb pipeline parameters",
    "description": "The proteogenomicsdb pipeline (formerly known as pgdb) creates custom protein databases for ProteoGenomics data analysis.",
    "type": "object",
    "$defs": {
        "input_output_options": {
            "title": "Input/output options",
            "type": "object",
            "fa_icon": "fas fa-terminal",
            "description": "Define where the pipeline should find input data and save output data.",
            "required": ["outdir"],
            "properties": {
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.",
                    "fa_icon": "fas fa-folder-open"
                }
            }
        },
        "generic_options": {
            "title": "Generic options",
            "type": "object",
            "fa_icon": "fas fa-file-import",
            "description": "Less common options for the pipeline, typically set in a config file.",
            "help_text": "These options are common to all nf-core pipelines and allow you to customise some of the core preferences for how the pipeline runs.\n\nTypically these options would be set in a Nextflow config file loaded for all pipeline runs, such as `~/.nextflow/config`.",
            "properties": {
                "version": {
                    "type": "boolean",
                    "description": "Display version and exit.",
                    "fa_icon": "fas fa-question-circle",
                    "hidden": true
                },
                "validate_params": {
                    "type": "boolean",
                    "description": "Boolean whether to validate parameters against the schema at runtime",
                    "default": true,
                    "fa_icon": "fas fa-check-square",
                    "hidden": true
                }
            }
        },
        "other_options": {
            "title": "other options",
            "type": "object",
            "description": "input files for running the workflow.",
            "properties": {
                "monochrome_logs": {
                    "type": "boolean",
                    "description": "placeholder text"
                },
                "help_full": {
                    "type": "boolean",
                    "description": "placeholder text"
                },
                "show_hidden": {
                    "type": "boolean",
                    "description": "placeholder text"
                },
                "email": {
                    "type": "string",
                    "description": "placeholder text"
                },
                "email_on_fail": {
                    "type": "string",
                    "description": "placeholder text"
                },
                "plaintext_email": {
                    "type": "boolean",
                    "description": "placeholder text"
                },
                "hook_url": {
                    "type": "string",
                    "description": "placeholder text"
                },
                "custom_config_base": {
                    "type": "string",
                    "default": "https://raw.githubusercontent.com/nf-core/configs/master",
                    "description": "placeholder text"
                },
                "custom_config_version": {
                    "type": "string",
                    "default": "master",
                    "description": "placeholder text"
                },
                "igenomes_base": {
                    "type": "string",
                    "default": "s3://ngi-igenomes/igenomes/",
                    "description": "placeholder text"
                },
                "igenomes_ignore": {
                    "type": "boolean",
                    "description": "placeholder text"
                },
                "publish_dir_mode": {
                    "type": "string",
                    "default": "copy",
                    "description": "placeholder text"
                },
                "pipelines_testdata_base_path": {
                    "type": "string",
                    "default": "https://raw.githubusercontent.com/nf-core/test-datasets/7f1614bae0ddf66e60be78c3d9fa55440465ac8/",
                    "description": "placeholder text"
                },
                "config_profile_name": {
                    "type": "string",
                    "description": "placeholder text"
                },
                "config_profile_description": {
                    "type": "string",
                    "description": "placeholder text"
                },
                "config_profile_contact": {
                    "type": "string",
                    "description": "placeholder text"
                },
                "config_profile_url": {
                    "type": "string",
                    "description": "placeholder text"
                }
            }
        },
        "skip_options": {
            "title": "skip_options",
            "type": "object",
            "description": "Paramiters that decide which processes to skip.",
            "properties": {
                "skip_rnaseqdb": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip the rnaseqdb workflow"
                },
                "skip_dnaseq": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip generating a database from cdna files generated from the sequening data"
                },
                "skip_vcf": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip generating a database from a vcf file based on the sequencing data"
                },
                "skip_ensembldb": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip the ensembldb workflow"
                },
                "skip_proteome": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip adding the ENSEMBL proteome data to the final database"
                },
                "skip_ncrna": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip database generation from non-coding rna data"
                },
                "skip_pseudogenes": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip database generation from pseudogene data"
                },
                "skip_altorfs": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip database generation from alternate reading frame data"
                },
                "skip_ensembl_vcf": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip database generation from an ENSEMBL vcf file"
                },
                "skip_cosmicdb": {
                    "type": "boolean",
                    "description": "option to skip the cosmicdb workflow",
                    "default": true
                },
                "skip_gencodedb": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip the gencodedb workflow"
                },
                "skip_cbioportaldb": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip the cbioportaldb workflow"
                },
                "skip_additional_database": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip the addition of an additional database"
                },
                "skip_decoy": {
                    "type": "boolean",
                    "default": true,
                    "description": "option to skip decoy generation"
                }
            }
        },
        "download_urls": {
            "title": "download_urls",
            "type": "object",
            "description": "Paramiters difining which files are downloaded.",
            "properties": {
                "cbioportal_url": {
                    "type": "string",
                    "description": "url for the cBioPortal study the user wants to download"
                },
                "grch38_url": {
                    "type": "string",
                    "default": "ftp://ftp.ensembl.org/pub/release-115/fasta/homo_sapiens/cdna/Homo_sapiens.GRCh38.cdna.all.fa.gz",
                    "description": "Download url for the human geneome GRCh38"
                },
                "cosmic_genes_url": {
                    "type": "string",
                    "default": "https://cancer.sanger.ac.uk/api/mono/products/v1/downloads/scripted?path=grch38/cosmic/v103/Cosmic_Genes_Fasta_v103_GRCh38.tar&bucket=downloads",
                    "description": "download url for the COSMIC gene data"
                },
                "cosmic_mutations_url": {
                    "type": "string",
                    "default": "https://cancer.sanger.ac.uk/api/mono/products/v1/downloads/scripted?path=grch38/cosmic/v103/Cosmic_GenomeScreensMutant_Tsv_v103_GRCh38.tar&bucket=downloads",
                    "description": "download url for the COSMIC mutations data"
                },
                "gencode_transcripts_url": {
                    "type": "string",
                    "default": "https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_49/gencode.v49.transcripts.fa.gz",
                    "description": "download url for gencode transcripts data"
                },
                "gencode_annotations_url": {
                    "type": "string",
                    "default": "https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_49/gencode.v49.primary_assembly.annotation.gtf.gz",
                    "description": "download url for gencode annotation data"
                },
                "gencode_reference_url": {
                    "type": "string",
                    "default": "https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_49/GRCh38.primary_assembly.genome.fa.gz",
                    "description": "download url for gencode genome reference"
                },
                "gnomad_url": {
                    "type": "string",
                    "default": "gs://gcp-public-data--gnomad/release/4.1/vcf/genomes/gnomad.genomes.v4.1.sites.*.vcf.bgz",
                    "description": "download url for gnomad vcf data"
                }
            }
        },
        "pypgatk_config_files": {
            "title": "pypgatk_config_files",
            "type": "object",
            "description": "Paramiters containing the config files for running the pypgatk modules.",
            "properties": {
                "dna_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/dna_config.yaml",
                    "description": "config file used in the RNASEQDB workflow in the PYPGATK_DNA process"
                },
                "custom_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/custom_config.yaml",
                    "description": "config file used in the RNASEQDB workflow in the PYPGATK_VCF process"
                },
                "gencode_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/gencode_config.yaml",
                    "description": "config file used in the gencodeDB workflow in the PYPGATK_VCF process"
                },
                "cbio_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/cbioportal_config.yaml",
                    "description": "config file used in the CBIOPORTALDB workflow in the PYPGATK_CBIOPORTAL process"
                },
                "ensembl_downloader_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/ensembl_downloader_config.yaml",
                    "description": "config file used in the ENSEMBLDB workflow in the PYPGATK_ENSEMBL_DOWNLOADER process"
                },
                "ensembl_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/ensembl_config.yaml",
                    "description": "config file used in the ENSEMBLDB workflow in the PYPGATK_VCF process"
                },
                "ncrna_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/ncrna_config.yaml",
                    "description": "config file used in the ENSEMBLDB workflow in the PYPGATK_NCRNA process"
                },
                "pseudogenes_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/pseudogenes_config.yaml",
                    "description": "config file used in the ENSEMBLDB workflow in the PYPGATK_PSEUDOGENES process"
                },
                "altorfs_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/altorfs_config.yaml",
                    "description": "config file used in the ENSEMBLDB workflow in the PYPGATK_ALTORFS process"
                },
                "cosmic_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/cosmic_config.yaml",
                    "description": "config file used in the COSMICDB workflow in the PYPGATK_COSMIC process"
                },
                "clean_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/clean_config.yaml",
                    "description": "config file used in the MERGEDB workflow in the ENSEMBL_CHECK process"
                },
                "decoy_config": {
                    "type": "string",
                    "default": "$projectDir/conf/pypgatk_config_files/protein_decoy.yaml",
                    "description": "config file used in the MERGEDB workflow in the PYPGATK_DECOY process"
                }
            }
        },
        "pipeline_inputs": {
            "title": "pipeline_inputs",
            "type": "object",
            "description": "paramiters for inputting into the pipeline.",
            "properties": {
                "annotation": {
                    "type": "string",
                    "description": "annotation (.gtf) file for RNASEQDB"
                },
                "reference": {
                    "type": "string",
                    "description": "genome reference (.fa) file for RNASEQDB"
                },
                "username": {
                    "type": "string",
                    "description": "COSMIC username"
                },
                "password": {
                    "type": "string",
                    "description": "COSMIC password"
                },
                "transcripts": {
                    "type": "string",
                    "description": "gene transcripts (.fa) file for RNASEQDB"
                },
                "species_id": {
                    "type": "integer",
                    "description": "ENSEMBL species id"
                },
                "cbio_study": {
                    "type": "string",
                    "description": "name of the cBioPortal study"
                },
                "faidx_get_genome_sizes": {
                    "type": "boolean",
                    "description": "boolean defining if the faidx should get the genome sized"
                },
                "additional_database": {
                    "type": "string",
                    "description": "Additional database to merge into final database"
                },
                "input": {
                    "type": "string",
                    "description": "sorted bam file inputted as a samplesheet"
                },
                "bam_index": {
                    "type": "string",
                    "description": "bam index file inputted as a samplesheet"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/input_output_options"
        },
        {
            "$ref": "#/$defs/generic_options"
        },
        {
            "$ref": "#/$defs/other_options"
        },
        {
            "$ref": "#/$defs/skip_options"
        },
        {
            "$ref": "#/$defs/download_urls"
        },
        {
            "$ref": "#/$defs/pypgatk_config_files"
        },
        {
            "$ref": "#/$defs/pipeline_inputs"
        }
    ]
}
